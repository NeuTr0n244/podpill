# Copy to .env.local and fill in real values.

# GLB asset URL. Leave blank in dev to use /public/podcastelon.glb;
# in production point at Cloudflare R2 / CDN.
VITE_GLB_URL=

# Gemini (Google AI) — for the GPT-style scripted dialogue.
# Get a key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash

# ElevenLabs — voice synthesis.
# Get a key: https://elevenlabs.io/app/settings/api-keys
# Find voice IDs at https://elevenlabs.io/app/voice-library
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ELON=
VITE_ELEVENLABS_VOICE_PENGUIN=
VITE_ELEVENLABS_VOICE_PUNCH=
